# Database — Neon Postgres connection string
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Auth.js
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"

# Google OAuth (optional)
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Stripe
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
# Token bundle product IDs from Stripe dashboard
STRIPE_PRODUCT_STARTER="prod_UBtWcCOazqHyNK"
STRIPE_PRODUCT_POPULAR="prod_UBtXj8Fzvuppjm"
STRIPE_PRODUCT_PREMIUM="prod_UBtYbs3B3jKoQi"

# EmailJS — https://www.emailjs.com
# Enable "Allow EmailJS API for non-browser applications" under Account → Security
# Create 3 templates (see EMAIL_SETUP.md for the HTML to paste into each)
EMAILJS_SERVICE_ID="service_xxxxxxx"
EMAILJS_PUBLIC_KEY="your_public_key"
EMAILJS_PRIVATE_KEY="your_private_key_from_account_security"
EMAILJS_VERIFY_TEMPLATE_ID="template_xxxxxxx"
EMAILJS_RESET_TEMPLATE_ID="template_xxxxxxx"
EMAILJS_WELCOME_TEMPLATE_ID="template_xxxxxxx"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
